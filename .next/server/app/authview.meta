{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/authview/layout,_N_T_/authview/page,_N_T_/authview"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/authview/__PAGE__",
    "/authview",
    "/_index",
    "/_head"
  ]
}