{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/devauthgate/layout,_N_T_/devauthgate/page,_N_T_/devauthgate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
