{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/search-pieces/layout,_N_T_/search-pieces/page,_N_T_/search-pieces"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/search-pieces/__PAGE__",
    "/search-pieces",
    "/_index",
    "/_head"
  ]
}