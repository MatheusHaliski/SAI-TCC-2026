{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/search-items/layout,_N_T_/search-items/page,_N_T_/search-items"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/search-items/__PAGE__",
    "/search-items",
    "/_index",
    "/_head"
  ]
}